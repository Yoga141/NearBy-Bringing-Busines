{
  "info": {
    "name": "API Translate",
    "description": "Local, offline, open-source ID <-> EN (and beyond) translation REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "List Supported Languages",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/languages"
      }
    },
    {
      "name": "Translate ID -> EN (explicit)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Halo dunia\",\n  \"from\": \"id\",\n  \"to\": \"en\"\n}"
        },
        "url": "{{baseUrl}}/translate"
      }
    },
    {
      "name": "Translate EN -> ID (explicit)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Hello world\",\n  \"from\": \"en\",\n  \"to\": \"id\"\n}"
        },
        "url": "{{baseUrl}}/translate"
      }
    },
    {
      "name": "Translate with Auto-Detect (no 'from')",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Selamat pagi, apa kabar?\",\n  \"to\": \"en\"\n}"
        },
        "url": "{{baseUrl}}/translate"
      }
    },
    {
      "name": "Translate with Formatting Preserved",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"# Selamat datang\\n\\nHubungi kami di **support@nearbybalikpapan.com** atau kunjungi https://nearbybalikpapan.com 🎉 Harga mulai dari Rp150.000.\",\n  \"from\": \"id\",\n  \"to\": \"en\"\n}"
        },
        "url": "{{baseUrl}}/translate"
      }
    },
    {
      "name": "Detect Language",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Saya suka belajar pemrograman\"\n}"
        },
        "url": "{{baseUrl}}/detect"
      }
    },
    {
      "name": "Validation Error (missing 'to')",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Halo dunia\"\n}"
        },
        "url": "{{baseUrl}}/translate"
      }
    }
  ]
}
