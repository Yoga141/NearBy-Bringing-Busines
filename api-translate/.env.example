# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# CORS -- prod sits same-origin behind Nginx (see README), this is a fallback.
# Comma-separated, add your local Vue dev origin too.
CORS_ORIGINS=https://nearbybalikpapan.com,https://www.nearbybalikpapan.com,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Models -- first request per pair auto-downloads unless pre-downloaded via `npm run download-models`
MODELS_CACHE_DIR=./models_cache
MODEL_MAX_INPUT_CHARS=5000
TRANSLATION_TIMEOUT_MS=30000

# Comma-separated pairs to load into memory on startup; empty = lazy-load
PRELOAD_LANGUAGE_PAIRS=id-en,en-id

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
